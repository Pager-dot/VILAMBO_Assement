GOOGLE_API_KEY=

# Per-node model overrides — swap cheap/dev vs demo/quality models without touching code.
# gemini-2.5-* / gemini-2.0-* 404 as "no longer available to new users" on new API keys,
# even with billing enabled. Pinned to gemini-3.5-flash-lite (rather than the rolling
# gemini-flash-lite-latest alias) so behavior doesn't shift if Google repoints it later.
# Check what's available on your key with:
#   curl "https://generativelanguage.googleapis.com/v1beta/models?key=$GOOGLE_API_KEY"
ANALYZER_MODEL=gemini-3.5-flash-lite
SUMMARIZER_MODEL=gemini-3.5-flash-lite
CITATION_MODEL=gemini-3.5-flash-lite
INSIGHTS_MODEL=gemini-3.5-flash-lite
REVIEWER_MODEL=gemini-3.5-flash-lite

LOG_LEVEL=INFO
